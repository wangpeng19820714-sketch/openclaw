{
  "gateway": {
    "mode": "local",
    "port": 18789,
    "auth": {
      "mode": "token",
      "token": "${OPENCLAW_GATEWAY_TOKEN}"
    }
  },
  "agents": {
    "defaults": {
      "workspace": "~/.openclaw/workspace",
      "model": {
        "primary": "openai-codex/gpt-5.3-codex",
        "fallbacks": ["google-gemini-cli/gemini-3-pro-preview"]
      }
    },
    "list": [
      {
        "id": "client",
        "default": true,
        "model": {
          "primary": "openai-codex/gpt-5.3-codex",
          "fallbacks": ["google-gemini-cli/gemini-3-pro-preview"]
        }
      },
      {
        "id": "server",
        "model": {
          "primary": "openai-codex/gpt-5.3-codex"
        }
      },
      {
        "id": "pm",
        "model": {
          "primary": "google-gemini-cli/gemini-3-pro-preview"
        }
      },
      {
        "id": "ba",
        "model": {
          "primary": "google-gemini-cli/gemini-3-pro-preview"
        }
      }
    ]
  },
  "auth": {
    "profiles": {
      "openai-codex:default": {
        "provider": "openai-codex",
        "mode": "oauth"
      },
      "google-gemini-cli:default": {
        "provider": "google-gemini-cli",
        "mode": "oauth"
      }
    },
    "order": {
      "openai-codex": ["openai-codex:default"],
      "google-gemini-cli": ["google-gemini-cli:default"]
    }
  },
  "skills": {
    "entries": {
      "notion": {
        "enabled": true,
        "apiKey": "${NOTION_API_KEY}"
      }
    }
  },
  "plugins": {
    "allow": ["feishu", "google-gemini-cli-auth", "device-pair"],
    "entries": {
      "feishu": {
        "enabled": true
      },
      "google-gemini-cli-auth": {
        "enabled": true
      }
    }
  },
  "channels": {
    "feishu": {
      "enabled": true,
      "connectionMode": "websocket",
      "domain": "feishu",
      "dmPolicy": "pairing",
      "groupPolicy": "open",
      "requireMention": false,
      "defaultAccount": "bot_main",
      "accounts": {
        "bot_main": {
          "appId": "${FEISHU_MAIN_APP_ID}",
          "appSecret": "${FEISHU_MAIN_APP_SECRET}"
        },
        "bot_client": {
          "appId": "${FEISHU_CLIENT_APP_ID}",
          "appSecret": "${FEISHU_CLIENT_APP_SECRET}"
        },
        "bot_server": {
          "enabled": false
        },
        "bot_pm": {
          "enabled": true,
          "appId": "${FEISHU_PM_APP_ID}",
          "appSecret": "${FEISHU_PM_APP_SECRET}"
        },
        "bot_ba": {
          "enabled": true,
          "appId": "${FEISHU_BA_APP_ID}",
          "appSecret": "${FEISHU_BA_APP_SECRET}"
        }
      }
    }
  },
  "bindings": [
    {
      "agentId": "main",
      "match": {
        "channel": "feishu",
        "accountId": "bot_main"
      }
    },
    {
      "agentId": "client",
      "match": {
        "channel": "feishu",
        "accountId": "bot_client"
      }
    },
    {
      "agentId": "server",
      "match": {
        "channel": "feishu",
        "accountId": "bot_server"
      }
    },
    {
      "agentId": "pm",
      "match": {
        "channel": "feishu",
        "accountId": "bot_pm"
      }
    },
    {
      "agentId": "ba",
      "match": {
        "channel": "feishu",
        "accountId": "bot_ba"
      }
    }
  ]
}
