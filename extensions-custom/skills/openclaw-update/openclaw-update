#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

resolve_repo_root() {
  local dir="$SCRIPT_DIR"
  while [[ "$dir" != "/" ]]; do
    if [[ -f "$dir/openclaw.mjs" ]]; then
      echo "$dir"
      return 0
    fi
    local parent
    parent="$(cd "$dir/.." && pwd)"
    if [[ "$parent" == "$dir" ]]; then
      break
    fi
    dir="$parent"
  done
  echo ""
}

REPO_ROOT="$(resolve_repo_root)"
if [[ -z "$REPO_ROOT" ]]; then
  echo "Could not locate openclaw.mjs from ${SCRIPT_DIR}." >&2
  exit 1
fi

OPENCLAW_BIN="${REPO_ROOT}/openclaw.mjs"
if [[ ! -f "$OPENCLAW_BIN" ]]; then
  echo "openclaw.mjs not found: ${OPENCLAW_BIN}" >&2
  exit 1
fi

REPO_CONFIG="${REPO_ROOT}/configs/openclaw.json"
if [[ -f "$REPO_CONFIG" ]]; then
  DEFAULT_CONFIG="$REPO_CONFIG"
else
  DEFAULT_CONFIG="${HOME}/.openclaw/openclaw.json"
fi

OPENCLAW_CONFIG_PATH="${OPENCLAW_CONFIG_PATH:-$DEFAULT_CONFIG}"
export OPENCLAW_CONFIG_PATH

require_command() {
  local cmd="$1"
  if ! command -v "$cmd" >/dev/null 2>&1; then
    echo "Missing required binary: ${cmd}" >&2
    exit 1
  fi
}

usage() {
  cat <<'EOF'
OpenClaw Update Skill

Usage:
  openclaw_update [openclaw update args]

Examples:
  /openclaw_update
  /openclaw_update --help
EOF
}

if [[ $# -eq 1 && "$1" == "--help" ]]; then
  usage
  exit 0
fi

normalize_arg() {
  local raw="$1"
  raw="${raw#/}"
  raw="${raw//-/_}"
  echo "$raw"
}

while [[ $# -gt 0 ]]; do
  first_normalized="$(normalize_arg "$1")"
  case "$first_normalized" in
    openclaw|openclaw_update)
      shift
      ;;
    *)
      break
      ;;
  esac
done

require_command node

(
  cd "$REPO_ROOT"
  if [[ $# -eq 0 ]]; then
    node "$OPENCLAW_BIN" update
  else
    node "$OPENCLAW_BIN" update "$@"
  fi
)
