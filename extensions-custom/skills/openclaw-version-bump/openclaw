#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

if [[ $# -eq 0 ]]; then
  exec "$SCRIPT_DIR/openclaw-version-bump" show
fi

# 支持常见别名：`openclaw`, `openclaw-version-bump`, `openclaw_version_bump`，以及直接语义命令。
if [[ "$1" == "openclaw" || "$1" == "openclaw-version-bump" || "$1" == "openclaw_version_bump" ]]; then
  shift
  if [[ $# -eq 0 ]]; then
    exec "$SCRIPT_DIR/openclaw-version-bump" show
  fi
  exec "$SCRIPT_DIR/openclaw-version-bump" "$@"
fi

if [[ "$1" == "查看当前版本" || "$1" == "查看版本" || "$1" == "版本" ]]; then
  exec "$SCRIPT_DIR/openclaw-version-bump" show
fi

if [[ "$1" == "show" || "$1" == "bump" || "$1" == "--help" || "$1" == "-h" ]]; then
  exec "$SCRIPT_DIR/openclaw-version-bump" "$@"
fi

exec "$SCRIPT_DIR/openclaw-version-bump" "$@"
