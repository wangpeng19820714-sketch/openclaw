#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

normalize_command() {
  local raw="$1"
  raw="${raw#/}"
  raw="${raw//-/_}"
  echo "$raw"
}

if [[ $# -eq 0 ]]; then
  exec "${SCRIPT_DIR}/openclaw-update"
fi

normalized_first="$(normalize_command "$1")"
if [[ "$normalized_first" == "openclaw" || "$normalized_first" == "openclaw_update" ]]; then
  shift
fi

exec "${SCRIPT_DIR}/openclaw-update" "$@"
